# ===== Active model =====
# Format: provider:model-id
# Examples (paid, cheap → expensive):
#   openai:gpt-4o-mini            (cheap default, ~$0.15/$0.60 per Mtoken)
#   openai:gpt-4.1
#   anthropic:claude-haiku-4-5
#   anthropic:claude-sonnet-4-6   (highest quality, $3/$15 per Mtoken)
#   google:gemini-2.5-flash
#   google:gemini-2.5-pro
#   deepseek:deepseek-chat        (~$0.27/$1.10 per Mtoken)
#   deepseek:deepseek-reasoner    (R1 reasoning model)
#
# Free / nearly-free (Groq — generous free tier + new-user credits):
#   groq:llama-3.3-70b-versatile  (best quality on Groq free tier)
#   groq:llama-3.1-8b-instant     (fastest, lower quality)
#   groq:mixtral-8x7b-32768
MODEL=openai:gpt-4o-mini

# ===== API keys =====
# Only the key matching your MODEL provider is required.
# Keep the others as placeholders if you plan to switch providers without re-onboarding.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
